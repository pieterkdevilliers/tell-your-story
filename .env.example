# Copy this file to .env and fill in the values you need.
# docker compose automatically loads .env from the project root.
# For non-Docker local backend dev, copy it to backend/.env instead
# (fastapi dev/run loads .env from its current working directory).

# --- Backend: required ---
JWT_SECRET_KEY=dev-secret-change-me

# --- Backend: optional (sensible defaults already in code) ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
DATABASE_URL=sqlite+aiosqlite:///./tell_your_story.db
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# --- Deploying behind a real domain (docker-compose.deploy.yml) ---
# The localhost defaults below only work for local dev. Once this is
# reachable at a real public hostname (e.g. via the Cloudflare Tunnel),
# set all three of these to that hostname, or the browser will hit CORS
# errors and any links the backend generates (invites, password resets)
# will point at localhost instead of somewhere reachable.
CORS_ORIGINS=http://localhost:3014
FRONTEND_URL=http://localhost:3014
NUXT_PUBLIC_API_BASE=http://localhost:8014

# --- Backend: AWS SES (optional) ---
# If SES_FROM_EMAIL is unset, password reset emails are logged to the
# backend console instead of being sent — the app works fully without
# any of these. Set them to actually send email via SES:
#   SES_FROM_EMAIL must be a verified sender identity in your SES account.
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION are read
#   automatically by boto3's standard AWS credential chain — no other
#   app-specific configuration is needed.
SES_FROM_EMAIL=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Backend: AWS S3 (optional) ---
# If S3_BUCKET_NAME is unset, recorded answer media, memoir PDFs, and
# cover photos are stored on local disk under MEDIA_ROOT — the app works
# fully without any of these. Set S3_BUCKET_NAME to switch storage to S3;
# it reuses the same AWS_REGION / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# from the SES section above (one IAM user's credentials can cover both,
# as long as its policy grants both SES sending and S3 read/write/delete
# on this bucket). The bucket should block all public access — every read
# already goes through an authenticated backend endpoint.
S3_BUCKET_NAME=

# --- Backend: Claude API (required for memoir generation) ---
# Without this, generating a memoir will fail (status shows as "failed" in
# the UI) — everything else in the app works fine without it.
ANTHROPIC_API_KEY=
